RewriteEngine On

# Disable MultiViews to prevent /blog from incorrectly matching blogs.php
Options -MultiViews -Indexes

# Redirect old blog posts to new blog location (clean URLs)
Redirect 301 /what-is-the-best-way-to-take-moringa-for-diabetes/ /blog/what-is-the-best-way-to-take-moringa-for-diabetes
Redirect 301 /will-your-knee-feel-100-percent-normal-after-acl-surgery-recovery-facts/ /blog/will-your-knee-feel-100-percent-normal-after-acl-surgery-recovery-facts
Redirect 301 /homeopathic-remedy-for-headache-natural-relief-guide/ /blog/homeopathic-remedy-for-headache-natural-relief-guide
Redirect 301 /pair-me-jhunjhuni-hona/ /blog/pair-me-jhunjhuni-hona
Redirect 301 /gas-se-peeth-dard-kyun-hota-hai/ /blog/gas-se-peeth-dard-kyun-hota-hai
Redirect 301 /pair-me-khujli-hona/ /blog/pair-me-khujli-hona
Redirect 301 /lungs-me-dard-hona/ /blog/lungs-me-dard-hona
Redirect 301 /pair-me-jalan/ /blog/pair-me-jalan
Redirect 301 /bp-high-hone-par-kya-kare/ /blog/bp-high-hone-par-kya-kare
Redirect 301 /hiv-symptoms-in-women/ /blog/hiv-symptoms-in-women
Redirect 301 /pair-me-sujan/ /blog/pair-me-sujan

# Redirect old department pages to new service pages
Redirect 301 /departments/ivf/ /ivf-treatment-in-ambikapur
Redirect 301 /departments/ent/ /ent-hospital-in-ambikapur
Redirect 301 /departments/orthopaedics-surgery/ /orthopedic-hospital-in-ambikapur
Redirect 301 /departments/obstetrics-gynecology/ /gynecology-hospital-in-ambikapur
Redirect 301 /departments/urology/ /urology-hospital-in-ambikapur
Redirect 301 /departments/ophthalmology/ /ophthalmology-hospital-in-ambikapur
Redirect 301 /departments/pediatrics/ /pediatric-hospital-in-ambikapur
Redirect 301 /departments/dialysis/ /dialysis-center-in-ambikapur
Redirect 301 /departments/laparoscopic-surgery/ /laparoscopic-surgery-hospital-in-ambikapur
Redirect 301 /departments/emergency/ /emergency-hospital-in-ambikapur
Redirect 301 /departments/chemotherapy/ /chemotherapy-hospital-in-ambikapur
Redirect 301 /departments/anesthesia/ /anesthesia-services-in-ambikapur
Redirect 301 /departments/oral-surgery/ /maxillofacial-surgery-hospital-in-ambikapur

# Redirect old doctor pages to clean URLs
Redirect 301 /doctors/dr-lata-goyal/ /doctors/dr-lata-goyal
Redirect 301 /doctors/dr-tanay-goyal/ /doctors/dr-tanay-goyal
Redirect 301 /doctors/dr-ankita-bansal-goyal/ /doctors/dr-ankita-bansal-goyal
Redirect 301 /doctors/dr-ankit-sharma/ /doctors/dr-ankit-sharma
Redirect 301 /doctors/dr-ankit-gupta/ /doctors/dr-ankit-gupta
Redirect 301 /doctors/dr-usha-armo/ /doctors/dr-usha-armo
Redirect 301 /doctors/dr-akshaya-goyal/ /doctors/dr-akshaya-goyal
Redirect 301 /doctors/dr-megha-goyal/ /doctors/dr-megha-goyal
Redirect 301 /doctors/dr-shailesh-gupta/ /doctors/dr-shailesh-gupta
Redirect 301 /doctors/dr-nilesh-goyal/ /doctors/dr-nilesh-goyal
Redirect 301 /doctors/dr-rimsha-lakesh-sahu/ /doctors/dr-rimsha-lakesh-sahu
Redirect 301 /doctors/dr-chandra-mukesh-dhawde/ /doctors/dr-chandra-mukesh-dhawde
Redirect 301 /doctors/dr-suneedh-gupta/ /doctors/dr-suneedh-gupta
Redirect 301 /doctors/dr-sanjay-goyal/ /doctors/dr-sanjay-goyal

# External redirect to remove .php extension
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /([^\ ]+)\.php
RewriteRule ^/?(.*)\.php$ /$1 [L,R=301]

# Internal rewrite to add .php extension back (if file exists)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^([^\.]+)$ $1.php [NC,L]